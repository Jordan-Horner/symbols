#!/usr/bin/env python3
"""symbols — source code intelligence tool.

Subcommands:
    symbols list <file>...              Symbol maps (functions, classes, types)
    symbols list -r <directory>         Recursive symbol scan
    symbols imports <file>...           Show imports for files
    symbols deps <file> [-t]            What does this file depend on?
    symbols dependents <file> [-t]      What depends on this file?
    symbols impact <file>               Impact analysis (direct + transitive)
    symbols graph [directory]            Project-wide dependency graph summary

Supports: Python, TypeScript/JavaScript/Svelte, Go, Java, Rust, C/C++,
Ruby, Kotlin, Swift, Scala, PHP, Bash.
"""

from __future__ import annotations

import argparse
import ast
import json
import os
import re
import sys
from pathlib import Path

# ── tree-sitter optional import ───────────────────────────────────────────────
try:
    from tree_sitter import Language as _TSLanguage, Parser as _TSParser
    _TS_AVAILABLE = True
except ImportError:
    _TS_AVAILABLE = False

try:
    from tree_sitter_languages import get_language as _ts_get_language_bundle
    _TS_BUNDLE_AVAILABLE = True
except (ImportError, Exception):
    _TS_BUNDLE_AVAILABLE = False

# Extension → tree-sitter language name
_TS_EXT_MAP: dict[str, str] = {
    ".go": "go", ".java": "java", ".cs": "c_sharp",
    ".kt": "kotlin", ".kts": "kotlin",
    ".rb": "ruby", ".rs": "rust", ".php": "php",
    ".swift": "swift", ".scala": "scala",
    ".c": "c", ".h": "c",
    ".cpp": "cpp", ".cc": "cpp", ".cxx": "cpp", ".hpp": "cpp",
    ".sh": "bash", ".bash": "bash",
}

_TS_NEW_API_MODULES: dict[str, str] = {
    "go": "tree_sitter_go",
    "java": "tree_sitter_java",
    "c_sharp": "tree_sitter_c_sharp",
    "kotlin": "tree_sitter_kotlin",
    "ruby": "tree_sitter_ruby",
    "rust": "tree_sitter_rust",
    "php": "tree_sitter_php",
    "swift": "tree_sitter_swift",
    "scala": "tree_sitter_scala",
    "c": "tree_sitter_c",
    "cpp": "tree_sitter_cpp",
    "bash": "tree_sitter_bash",
}

_TS_SYMBOL_TYPES: dict[str, set[str]] = {
    "go":      {"function_declaration", "method_declaration", "type_spec"},
    "java":    {"class_declaration", "interface_declaration", "enum_declaration", "method_declaration"},
    "c_sharp": {"class_declaration", "interface_declaration", "method_declaration", "struct_declaration"},
    "kotlin":  {"class_declaration", "function_declaration", "object_declaration"},
    "ruby":    {"class", "module", "method", "singleton_method"},
    "rust":    {"function_item", "struct_item", "impl_item", "trait_item", "enum_item"},
    "php":     {"function_definition", "class_declaration", "interface_declaration"},
    "swift":   {"function_declaration", "class_declaration", "struct_declaration", "protocol_declaration"},
    "scala":   {"function_definition", "class_definition", "object_definition", "trait_definition"},
    "c":       {"function_definition", "struct_specifier"},
    "cpp":     {"function_definition", "class_specifier", "struct_specifier"},
    "bash":    {"function_definition"},
}

_TS_TOPLEVEL_PARENTS = {
    "source_file", "program", "compilation_unit", "class_body",
    "declaration_list", "class_declaration", "interface_body",
    "type_declaration",
}

_TS_FUNC_CLASS = re.compile(
    r'^(?:export\s+(?:default\s+)?)?(?:declare\s+)?(?:abstract\s+)?(?:async\s+)?'
    r'(function\*?|class|interface|type|enum)\s+([A-Za-z_$][A-Za-z0-9_$]*)',
)
_TS_VAR_EXPORT = re.compile(
    r'^export\s+(?:declare\s+)?(?:const|let|var)\s+([A-Za-z_$][A-Za-z0-9_$]*)',
)

_SUPPORTED_EXTS = (
    {".py", ".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".svelte"}
    | set(_TS_EXT_MAP.keys())
)

_ts_parser_cache: dict[str, object] = {}


def _get_ts_parser(lang_name: str) -> object:
    if lang_name in _ts_parser_cache:
        return _ts_parser_cache[lang_name]
    if _TS_AVAILABLE:
        mod_name = _TS_NEW_API_MODULES.get(lang_name)
        if mod_name:
            import importlib
            try:
                mod = importlib.import_module(mod_name)
                lang = _TSLanguage(mod.language())
                parser = _TSParser(lang)
                _ts_parser_cache[lang_name] = parser
                return parser
            except (ImportError, Exception):
                pass
    if _TS_BUNDLE_AVAILABLE:
        lang = _ts_get_language_bundle(lang_name)
        parser = _TSParser()
        parser.set_language(lang)
        _ts_parser_cache[lang_name] = parser
        return parser
    raise ImportError(f"No tree-sitter grammar available for {lang_name!r}")


def _extract_treesitter(content: str, lang_name: str) -> list[dict]:
    parser = _get_ts_parser(lang_name)
    tree = parser.parse(content.encode("utf-8", errors="replace"))
    symbol_types = _TS_SYMBOL_TYPES.get(lang_name, set())
    symbols: list[dict] = []

    def _walk(node: object) -> None:
        if node.type in symbol_types:
            parent_type = node.parent.type if node.parent else "source_file"
            if parent_type in _TS_TOPLEVEL_PARENTS:
                name_node = node.child_by_field_name("name")
                raw = name_node.text if name_node else None
                name = raw.decode("utf-8", errors="replace") if isinstance(raw, bytes) else (raw or "")
                if name:
                    kind = (node.type
                            .replace("_declaration", "")
                            .replace("_definition", "")
                            .replace("_item", "")
                            .replace("_specifier", "")
                            .replace("_spec", ""))
                    symbols.append({"name": name, "kind": kind, "line": node.start_point[0] + 1})
        for child in node.children:
            _walk(child)

    _walk(tree.root_node)
    return symbols


def _extract_python(content: str) -> list[dict]:
    try:
        tree = ast.parse(content)
    except SyntaxError:
        return []
    symbols: list[dict] = []
    for node in ast.iter_child_nodes(tree):
        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
            kind = "async def" if isinstance(node, ast.AsyncFunctionDef) else "def"
            args = ", ".join(a.arg for a in node.args.args[:4])
            ellipsis = ", ..." if len(node.args.args) > 4 else ""
            symbols.append({"name": f"{node.name}({args}{ellipsis})", "kind": kind, "line": node.lineno})
        elif isinstance(node, ast.ClassDef):
            symbols.append({"name": node.name, "kind": "class", "line": node.lineno})
    return symbols


def _extract_ts_js(content: str) -> list[dict]:
    symbols: list[dict] = []
    for lineno, line in enumerate(content.splitlines(), 1):
        m = _TS_FUNC_CLASS.match(line)
        if m:
            symbols.append({"name": m.group(2), "kind": m.group(1), "line": lineno})
            continue
        m = _TS_VAR_EXPORT.match(line)
        if m:
            symbols.append({"name": m.group(1), "kind": "export const", "line": lineno})
    return symbols


def extract_symbols(file_path: str) -> dict:
    path = Path(file_path)
    ext = path.suffix.lower()
    rel = str(path)

    if ext not in _SUPPORTED_EXTS:
        return {"file": rel, "error": f"unsupported extension: {ext}", "symbols": []}

    try:
        content = path.read_text(encoding="utf-8", errors="replace")
    except OSError as e:
        return {"file": rel, "error": str(e), "symbols": []}

    total_lines = len(content.splitlines())
    try:
        if ext == ".py":
            symbols = _extract_python(content)
        elif ext in (".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".svelte"):
            symbols = _extract_ts_js(content)
        else:
            lang_name = _TS_EXT_MAP.get(ext)
            if lang_name:
                symbols = _extract_treesitter(content, lang_name)
            else:
                symbols = []
    except (ImportError, Exception) as e:
        return {"file": rel, "error": str(e), "lines": total_lines, "symbols": []}

    return {"file": rel, "lines": total_lines, "symbols": symbols}


def format_text(result: dict) -> str:
    if result.get("error"):
        return f"### `{result['file']}` — error: {result['error']}\n"
    if not result["symbols"]:
        return f"### `{result['file']}` — {result.get('lines', '?')} lines (no symbols found)\n"
    lines = [f"### `{result['file']}` — {result['lines']} lines\n"]
    for s in result["symbols"]:
        lines.append(f"  {s['kind']} {s['name']}  # line {s['line']}")
    return "\n".join(lines)


_SKIP_DIRS = {
    ".git", "node_modules", "__pycache__", "dist", "build",
    ".venv", "venv", ".tox", ".mypy_cache", ".next", ".nuxt",
    "storybook-static", "coverage", ".turbo", ".parcel-cache",
    "target",  # Rust/Java build output
    "vendor",  # Go/PHP vendor deps
    "Pods",    # iOS
    ".gradle", "bin", "obj",  # C#/Java build
}


def collect_files(paths: list[str], recursive: bool) -> list[str]:
    files: list[str] = []
    for p in paths:
        path = Path(p)
        if path.is_file():
            if path.suffix.lower() in _SUPPORTED_EXTS:
                files.append(str(path.resolve()))
        elif path.is_dir():
            if recursive:
                # Use os.walk for directory pruning (rglob walks .git etc.)
                for dirpath, dirnames, filenames in os.walk(path):
                    # Prune skip dirs in-place to prevent descent
                    dirnames[:] = [
                        d for d in dirnames
                        if d not in _SKIP_DIRS and not d.startswith(".")
                    ]
                    dirnames.sort()
                    for fname in sorted(filenames):
                        if Path(fname).suffix.lower() in _SUPPORTED_EXTS:
                            files.append(str(Path(dirpath, fname).resolve()))
            else:
                for f in sorted(path.iterdir()):
                    if f.is_file() and f.suffix.lower() in _SUPPORTED_EXTS:
                        files.append(str(f.resolve()))
        else:
            print(f"warning: {p} not found", file=sys.stderr)
    return files


def _find_project_root(start: str) -> str:
    """Walk up to find project root (has .git, package.json, or pyproject.toml)."""
    current = Path(start).resolve()
    if current.is_file():
        current = current.parent
    for d in [current, *current.parents]:
        if (d / ".git").exists() or (d / "package.json").exists() or (d / "pyproject.toml").exists():
            return str(d)
    return str(current)


# ── Subcommand handlers ──────────────────────────────────────────────────────

def cmd_list(args: argparse.Namespace) -> None:
    files = collect_files(args.paths, args.recursive)
    if not files:
        print("No supported files found.", file=sys.stderr)
        sys.exit(1)
    results = [extract_symbols(f) for f in files]
    if args.json_output:
        json.dump(results, sys.stdout, indent=2)
        print()
    else:
        for r in results:
            print(format_text(r))


def cmd_imports(args: argparse.Namespace) -> None:
    from graph import extract_imports, format_imports_text
    files = collect_files(args.paths, args.recursive)
    if not files:
        print("No supported files found.", file=sys.stderr)
        sys.exit(1)
    results = [extract_imports(f) for f in files]
    if args.json_output:
        json.dump(results, sys.stdout, indent=2)
        print()
    else:
        for r in results:
            print(format_imports_text(r))


def _build_graph(target: str, root: str | None = None):
    from graph import build_graph
    if root is None:
        root = _find_project_root(target)
    files = collect_files([root], recursive=True)
    return build_graph(root, files), root


def cmd_deps(args: argparse.Namespace) -> None:
    from graph import format_deps_text
    graph, root = _build_graph(args.file, args.root)
    deps = graph.deps(args.file, transitive=args.transitive)
    if args.json_output:
        json.dump({"file": args.file, "deps": [graph._rel(d) for d in deps]}, sys.stdout, indent=2)
        print()
    else:
        label = "depends on (transitive)" if args.transitive else "depends on"
        print(format_deps_text(args.file, deps, root, label))


def cmd_dependents(args: argparse.Namespace) -> None:
    from graph import format_deps_text
    graph, root = _build_graph(args.file, args.root)
    deps = graph.dependents(args.file, transitive=args.transitive)
    if args.json_output:
        json.dump({"file": args.file, "dependents": [graph._rel(d) for d in deps]}, sys.stdout, indent=2)
        print()
    else:
        label = "depended on by (transitive)" if args.transitive else "depended on by"
        print(format_deps_text(args.file, deps, root, label))


def cmd_impact(args: argparse.Namespace) -> None:
    from graph import format_impact_text
    graph, root = _build_graph(args.file, args.root)
    result = graph.impact(args.file)
    if args.json_output:
        json.dump(result, sys.stdout, indent=2)
        print()
    else:
        print(format_impact_text(result))


def cmd_graph(args: argparse.Namespace) -> None:
    from graph import format_summary_text
    root = args.root or _find_project_root(args.directory or ".")
    files = collect_files([root], recursive=True)
    from graph import build_graph
    graph = build_graph(root, files)
    result = graph.summary()
    if args.json_output:
        json.dump(result, sys.stdout, indent=2)
        print()
    else:
        print(format_summary_text(result))


# ── CLI ───────────────────────────────────────────────────────────────────────

_SUBCOMMANDS = {"list", "imports", "deps", "dependents", "impact", "graph"}


def main() -> None:
    # Backward compat: if first non-flag arg isn't a subcommand, inject "list"
    # This lets `symbols foo.py` and `symbols -r dir/` work as before
    argv = sys.argv[1:]
    first_positional = next((a for a in argv if not a.startswith("-")), None)
    if first_positional and first_positional not in _SUBCOMMANDS:
        # Inject "list" before everything — all flags belong to the list subparser
        argv.insert(0, "list")

    parser = argparse.ArgumentParser(
        description="Source code intelligence tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    def _add_json(p: argparse.ArgumentParser) -> None:
        p.add_argument("--json", action="store_true", dest="json_output", help="Output as JSON")

    # list (default — symbol extraction)
    p_list = sub.add_parser("list", help="Extract top-level symbols from files")
    p_list.add_argument("paths", nargs="+", help="Files or directories")
    p_list.add_argument("-r", "--recursive", action="store_true")
    _add_json(p_list)
    p_list.set_defaults(func=cmd_list)

    # imports
    p_imports = sub.add_parser("imports", help="Show imports for files")
    p_imports.add_argument("paths", nargs="+", help="Files or directories")
    p_imports.add_argument("-r", "--recursive", action="store_true")
    _add_json(p_imports)
    p_imports.set_defaults(func=cmd_imports)

    # deps
    p_deps = sub.add_parser("deps", help="What does this file depend on?")
    p_deps.add_argument("file", help="File to analyze")
    p_deps.add_argument("-t", "--transitive", action="store_true", help="Include transitive deps")
    p_deps.add_argument("--root", help="Project root (auto-detected if omitted)")
    _add_json(p_deps)
    p_deps.set_defaults(func=cmd_deps)

    # dependents
    p_depts = sub.add_parser("dependents", help="What depends on this file?")
    p_depts.add_argument("file", help="File to analyze")
    p_depts.add_argument("-t", "--transitive", action="store_true", help="Include transitive dependents")
    p_depts.add_argument("--root", help="Project root (auto-detected if omitted)")
    _add_json(p_depts)
    p_depts.set_defaults(func=cmd_dependents)

    # impact
    p_impact = sub.add_parser("impact", help="Impact analysis for a file")
    p_impact.add_argument("file", help="File to analyze")
    p_impact.add_argument("--root", help="Project root (auto-detected if omitted)")
    _add_json(p_impact)
    p_impact.set_defaults(func=cmd_impact)

    # graph
    p_graph = sub.add_parser("graph", help="Project-wide dependency graph summary")
    p_graph.add_argument("directory", nargs="?", default=".", help="Project directory")
    p_graph.add_argument("--root", help="Project root (auto-detected if omitted)")
    _add_json(p_graph)
    p_graph.set_defaults(func=cmd_graph)

    args = parser.parse_args(argv)

    if not args.command:
        parser.print_help()
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()
